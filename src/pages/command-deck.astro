<script is:inline>
// nav scroll
const nav=document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>20));

// reveal on scroll
const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.15});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

// count up
function countUp(el){
  const to=parseFloat(el.dataset.to), suf=el.dataset.suffix||'', dur=1400, t0=performance.now();
  function tick(t){let p=Math.min((t-t0)/dur,1); p=1-Math.pow(1-p,3);
    let val=to*p; el.textContent=(suf?val.toFixed(1):Math.round(val));
    if(p<1)requestAnimationFrame(tick); else el.textContent=(suf?to.toFixed(1):to);}
  requestAnimationFrame(tick);
}
const cuio=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){countUp(e.target);cuio.unobserve(e.target);}})},{threshold:.6});
document.querySelectorAll('.cu').forEach(el=>cuio.observe(el));

// hero terminal
const lines=[
  {t:'00:00.2',st:'RESOLVE',ms:'Intent → <span class="tok ind">PATCH_DEPLOYMENT</span> · scope "all browsers"'},
  {t:'00:00.8',st:'RESOLVE',ms:'Matched <span class="tok ind">Firefox</span> · <span class="tok ind">Chrome</span> · <span class="tok ind">Edge</span>'},
  {t:'00:01.4',st:'CORRELATE',ms:'De-duped 412 findings → <b style="color:var(--t1)">128</b> unique'},
  {t:'00:01.9',st:'TARGET',ms:'<b style="color:var(--t1)">17</b> assets outdated · <span class="tok kev">1 KEV</span> exposure'},
  {t:'00:02.5',st:'PLAN',ms:'Pilot ring 3 → full rollout · reboot deferred'},
  {t:'00:03.1',st:'READY',ms:'<span class="tok ok">Draft ready</span> — review before creating'},
];
const body=document.getElementById('termBody'), rail=document.getElementById('termRail'), pct=document.getElementById('termPct');
let li=0;
function typeLine(){
  if(li>=lines.length){setTimeout(()=>{body.innerHTML='';li=0;rail.style.width='0';pct.textContent='0%';typeLine();},2600);return;}
  const l=lines[li];
  const div=document.createElement('div');div.className='tline';
  div.innerHTML=`<span class="tm">${l.t}</span><span class="st">${l.st}</span><span class="ms">${l.ms}<span class="caret"></span></span>`;
  body.appendChild(div);requestAnimationFrame(()=>div.classList.add('show'));
  // remove caret from previous
  const carets=body.querySelectorAll('.caret');carets.forEach((c,i)=>{if(i<carets.length-1)c.remove();});
  li++;const p=Math.round(li/lines.length*100);rail.style.width=p+'%';pct.textContent=p+'%';
  setTimeout(typeLine, li===lines.length?700:600);
}
setTimeout(typeLine,700);
</script>
