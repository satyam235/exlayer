---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Ex-Layer — The AI Remediation Execution Layer" themeColor="#07071a" fontHref={"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"}>
<style is:inline slot="head">
:root{
  --ink:#07071a; --panel:#0c0c1e; --panel-2:#11112a; --line:rgba(255,255,255,.08); --line-2:rgba(255,255,255,.14);
  --ind:#7b8cff; --ind-br:#9ba8ff; --ind-soft:rgba(123,140,255,.12); --ind-glow:rgba(123,140,255,.4);
  --em:#3dd68c; --mag:#ff3268; --amber:#f5a623;
  --t1:#eef0f8; --t2:#a7adc6; --t3:#5c6080;
  --sans:'Outfit',sans-serif; --mono:'JetBrains Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:var(--sans);background:var(--ink);color:var(--t1);overflow-x:hidden;line-height:1.5;
  background:radial-gradient(ellipse 90% 50% at 15% -5%,rgba(123,140,255,.13),transparent 55%),
    radial-gradient(ellipse 70% 50% at 95% 8%,rgba(255,50,104,.05),transparent 55%),var(--ink);}
::selection{background:rgba(123,140,255,.3);}
a{color:inherit;text-decoration:none;}
.wrap{max-width:1200px;margin:0 auto;padding:0 32px;}
.mono{font-family:var(--mono);}

/* dot grid */
.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:radial-gradient(circle,rgba(255,255,255,.05) 1px,transparent 1px);background-size:34px 34px;
  -webkit-mask-image:radial-gradient(ellipse 90% 70% at 50% 0%,#000 30%,transparent 75%);
  mask-image:radial-gradient(ellipse 90% 70% at 50% 0%,#000 30%,transparent 75%);}

/* nav */
nav{position:fixed;top:0;left:0;right:0;z-index:50;transition:background .3s,border-color .3s,backdrop-filter .3s;border-bottom:1px solid transparent;}
nav.scrolled{background:rgba(7,7,26,.72);backdrop-filter:blur(14px);border-bottom-color:var(--line);}
.nav-in{display:flex;align-items:center;justify-content:space-between;height:68px;}
.logo{display:flex;align-items:center;gap:10px;font-weight:700;font-size:18px;letter-spacing:-.02em;}
.logo-mark{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--ind-br),var(--ind));
  display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px -2px var(--ind-glow);position:relative;}
.logo-mark::before{content:'';position:absolute;inset:6px;border:1.5px solid #08071c;border-radius:3px;opacity:.85;}
.logo-mark::after{content:'';position:absolute;width:11px;height:11px;border-radius:2px;background:#08071c;}
.nav-links{display:flex;align-items:center;gap:34px;}
.nav-links a{font-size:14px;color:var(--t2);transition:color .2s;}
.nav-links a:hover{color:var(--t1);}
@media(max-width:820px){.nav-links a:not(.btn){display:none;}}
.btn{display:inline-flex;align-items:center;gap:8px;font-family:var(--sans);font-weight:600;font-size:14px;cursor:pointer;border:none;transition:transform .15s cubic-bezier(.16,1,.3,1),box-shadow .2s,background .2s;}
.btn-pri{background:linear-gradient(180deg,var(--ind-br),var(--ind));color:#08071c;padding:11px 20px;border-radius:10px;
  box-shadow:0 8px 24px -8px var(--ind-glow),inset 0 1px 0 rgba(255,255,255,.3);}
.btn-pri:hover{transform:translateY(-2px);box-shadow:0 14px 34px -8px var(--ind-glow),inset 0 1px 0 rgba(255,255,255,.35);}
.btn-ghost{background:rgba(255,255,255,.04);color:var(--t1);padding:11px 20px;border-radius:10px;border:1px solid var(--line-2);}
.btn-ghost:hover{background:rgba(255,255,255,.08);transform:translateY(-2px);}

/* hero */
.hero{position:relative;z-index:1;padding:150px 0 90px;}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:center;}
@media(max-width:980px){.hero-grid{grid-template-columns:1fr;gap:48px;}}
.eyebrow{display:inline-flex;align-items:center;gap:9px;font-family:var(--mono);font-size:11.5px;letter-spacing:.2em;
  text-transform:uppercase;color:var(--ind-br);border:1px solid var(--ind-soft);background:var(--ind-soft);
  padding:7px 14px;border-radius:999px;margin-bottom:26px;}
.eyebrow .pulse{width:6px;height:6px;border-radius:50%;background:var(--em);box-shadow:0 0 0 0 rgba(61,214,140,.6);animation:ping 2.2s infinite;}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(61,214,140,.5);}70%{box-shadow:0 0 0 8px rgba(61,214,140,0);}100%{box-shadow:0 0 0 0 rgba(61,214,140,0);}}
h1{font-size:clamp(40px,5.6vw,68px);font-weight:800;letter-spacing:-.035em;line-height:1.04;margin-bottom:22px;}
h1 em{font-style:normal;position:relative;background:linear-gradient(100deg,var(--ind-br),#c7ceff 60%,var(--ind));-webkit-background-clip:text;background-clip:text;color:transparent;}
.sub{font-size:18px;color:var(--t2);line-height:1.6;max-width:560px;margin-bottom:34px;}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;align-items:center;}
.hero-note{margin-top:22px;font-family:var(--mono);font-size:12px;color:var(--t3);display:flex;gap:10px;align-items:center;}
.hero-note b{color:var(--t2);font-weight:500;}

/* terminal */
.term{border:1px solid var(--line-2);border-radius:16px;overflow:hidden;background:rgba(10,10,26,.85);
  box-shadow:0 40px 90px -30px rgba(0,0,0,.9),0 0 0 1px rgba(123,140,255,.06);backdrop-filter:blur(4px);position:relative;}
.term::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(123,140,255,.6),transparent);}
.term-bar{display:flex;align-items:center;gap:8px;padding:13px 16px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.02);}
.term-bar .dot{width:11px;height:11px;border-radius:50%;}
.term-bar .dot:nth-child(1){background:#ff5f57;}.term-bar .dot:nth-child(2){background:#febc2e;}.term-bar .dot:nth-child(3){background:#28c840;}
.term-title{margin-left:8px;font-family:var(--mono);font-size:11.5px;color:var(--t3);}
.term-live{margin-left:auto;font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--em);display:flex;align-items:center;gap:6px;}
.term-live .d{width:6px;height:6px;border-radius:50%;background:var(--em);box-shadow:0 0 8px var(--em);}
.term-body{padding:18px 18px;font-family:var(--mono);font-size:12.5px;line-height:1.9;min-height:230px;}
.tline{display:flex;gap:12px;opacity:0;transform:translateY(4px);}
.tline.show{opacity:1;transform:none;transition:all .3s;}
.tline .tm{color:var(--t3);flex-shrink:0;}
.tline .st{flex-shrink:0;width:74px;color:var(--ind-br);font-weight:500;}
.tline .ms{color:var(--t2);}
.tok{padding:1px 6px;border-radius:4px;font-weight:500;}
.tok.ind{color:var(--ind-br);background:var(--ind-soft);}
.tok.crit{color:#ff7a9c;background:rgba(255,50,104,.14);}
.tok.kev{color:var(--amber);background:rgba(245,166,35,.14);}
.tok.ok{color:var(--em);background:rgba(61,214,140,.14);}
.caret{display:inline-block;width:7px;height:14px;background:var(--ind);vertical-align:-2px;animation:blink 1s steps(1) infinite;}
@keyframes blink{50%{opacity:0;}}
.term-foot{display:flex;align-items:center;gap:10px;padding:12px 18px;border-top:1px solid var(--line);background:rgba(255,255,255,.02);font-family:var(--mono);font-size:11px;color:var(--t3);}
.term-foot .rail{flex:1;height:4px;border-radius:3px;background:rgba(255,255,255,.07);overflow:hidden;}
.term-foot .rail i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--ind),var(--ind-br));border-radius:3px;transition:width .4s;}

/* reveal */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1);}
.reveal.in{opacity:1;transform:none;}
.reveal.d1{transition-delay:.08s;}.reveal.d2{transition-delay:.16s;}.reveal.d3{transition-delay:.24s;}.reveal.d4{transition-delay:.32s;}

/* section shells */
section{position:relative;z-index:1;}
.sec-head{text-align:center;max-width:680px;margin:0 auto 56px;}
.sec-eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:var(--ind-br);margin-bottom:14px;}
.sec-title{font-size:clamp(30px,4vw,46px);font-weight:800;letter-spacing:-.03em;line-height:1.1;margin-bottom:16px;}
.sec-sub{color:var(--t2);font-size:16px;line-height:1.6;}

/* trust */
.trust{padding:54px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.trust-lbl{text-align:center;font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--t3);margin-bottom:28px;}
.logos{display:flex;flex-wrap:wrap;justify-content:center;gap:14px;}
.logo-pill{display:inline-flex;align-items:center;gap:10px;border:1px solid var(--line);border-radius:12px;padding:11px 16px;background:rgba(255,255,255,.02);transition:border-color .25s,transform .25s,background .25s;}
.logo-pill:hover{border-color:var(--ind-soft);transform:translateY(-3px);background:rgba(123,140,255,.05);}
.logo-pill .lm{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:600;font-size:12px;color:#08071c;}
.logo-pill span{font-size:13.5px;font-weight:500;color:var(--t2);white-space:nowrap;}

/* problem stats */
.stats{padding:96px 0;}
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
@media(max-width:820px){.stat-grid{grid-template-columns:1fr;}}
.stat{border:1px solid var(--line);border-radius:18px;padding:34px 30px;background:linear-gradient(180deg,rgba(255,255,255,.03),transparent);position:relative;overflow:hidden;}
.stat::after{content:'';position:absolute;top:0;left:24px;width:40px;height:2px;background:var(--mag);border-radius:2px;}
.stat .num{font-size:54px;font-weight:800;letter-spacing:-.03em;line-height:1;margin-bottom:12px;font-feature-settings:"tnum";}
.stat .num span{font-size:30px;color:var(--t3);}
.stat .lbl{color:var(--t2);font-size:14.5px;line-height:1.55;}
.stat.s2::after{background:var(--amber);}.stat.s3::after{background:var(--ind);}

/* how it works */
.how{padding:96px 0;}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;position:relative;}
@media(max-width:980px){.steps{grid-template-columns:repeat(2,1fr);}}
@media(max-width:560px){.steps{grid-template-columns:1fr;}}
.step{border:1px solid var(--line);border-radius:18px;padding:28px 24px;background:var(--panel);transition:border-color .3s,transform .3s,box-shadow .3s;position:relative;}
.step:hover{border-color:var(--ind-soft);transform:translateY(-5px);box-shadow:0 24px 50px -28px var(--ind-glow);}
.step .n{font-family:var(--mono);font-size:11px;color:var(--ind-br);letter-spacing:.1em;margin-bottom:18px;}
.step .ic{width:46px;height:46px;border-radius:12px;background:var(--ind-soft);border:1px solid var(--ind-soft);display:flex;align-items:center;justify-content:center;margin-bottom:18px;color:var(--ind-br);}
.step h3{font-size:18px;font-weight:700;letter-spacing:-.01em;margin-bottom:9px;}
.step p{color:var(--t2);font-size:13.5px;line-height:1.6;}
.step .arrow{position:absolute;right:-13px;top:54px;color:var(--t3);z-index:2;}
@media(max-width:980px){.step .arrow{display:none;}}

/* engine deep dive */
.engine{padding:96px 0;}
.eng-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
@media(max-width:980px){.eng-grid{grid-template-columns:1fr;gap:44px;}}
.eng-list{margin-top:28px;display:flex;flex-direction:column;gap:18px;}
.eng-item{display:flex;gap:14px;}
.eng-item .ck{width:24px;height:24px;border-radius:7px;background:rgba(61,214,140,.12);border:1px solid rgba(61,214,140,.3);display:flex;align-items:center;justify-content:center;color:var(--em);flex-shrink:0;}
.eng-item h4{font-size:15.5px;font-weight:600;margin-bottom:3px;}
.eng-item p{color:var(--t2);font-size:13.5px;line-height:1.55;}
/* campaign card */
.camp{border:1px solid var(--line-2);border-radius:16px;background:rgba(13,13,31,.9);overflow:hidden;box-shadow:0 30px 70px -28px rgba(0,0,0,.85);}
.camp-top{padding:18px 20px;border-bottom:1px solid var(--line);}
.camp-chips{display:flex;gap:7px;margin-bottom:12px;flex-wrap:wrap;}
.chip{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.06em;padding:4px 9px;border-radius:999px;border:1px solid var(--line-2);}
.chip.crit{color:#ff7a9c;border-color:rgba(255,50,104,.4);background:rgba(255,50,104,.12);}
.chip.kev{color:var(--amber);border-color:rgba(245,166,35,.4);background:rgba(245,166,35,.12);}
.chip.act{color:var(--ind-br);border-color:var(--ind-soft);background:var(--ind-soft);}
.camp-title{font-size:16.5px;font-weight:700;letter-spacing:-.01em;}
.camp-rows{padding:8px 20px 16px;}
.crow{display:flex;justify-content:space-between;padding:11px 0;border-top:1px solid var(--line);font-size:13px;color:var(--t2);}
.crow:first-child{border-top:none;}
.crow .v{font-family:var(--mono);font-size:12px;color:var(--t1);}
.crow .v.ok{color:var(--em);}
.camp-foot{padding:14px 20px;border-top:1px solid var(--line);display:flex;gap:10px;}
.camp-foot .b1{flex:1;text-align:center;background:linear-gradient(180deg,var(--ind-br),var(--ind));color:#08071c;font-weight:600;font-size:13px;padding:10px;border-radius:9px;}
.camp-foot .b2{text-align:center;color:var(--t2);font-size:13px;padding:10px 16px;border-radius:9px;border:1px solid var(--line-2);}

/* outcomes */
.outcomes{padding:96px 0;}
.out-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
@media(max-width:820px){.out-grid{grid-template-columns:repeat(2,1fr);}}
.out{text-align:center;padding:20px;}
.out .num{font-size:clamp(40px,5vw,58px);font-weight:800;letter-spacing:-.03em;line-height:1;
  background:linear-gradient(180deg,#fff,var(--ind-br));-webkit-background-clip:text;background-clip:text;color:transparent;font-feature-settings:"tnum";}
.out .lbl{color:var(--t2);font-size:14px;margin-top:10px;}

/* security */
.sec-strip{padding:90px 0;}
.sec-card{border:1px solid var(--line);border-radius:24px;background:linear-gradient(135deg,rgba(123,140,255,.07),rgba(13,13,31,.6));padding:54px;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}
@media(max-width:820px){.sec-card{grid-template-columns:1fr;padding:36px;gap:32px;}}
.badges{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.badge{display:flex;align-items:center;gap:12px;border:1px solid var(--line);border-radius:12px;padding:14px 16px;background:rgba(255,255,255,.02);}
.badge .ic{width:34px;height:34px;border-radius:9px;background:var(--ind-soft);display:flex;align-items:center;justify-content:center;color:var(--ind-br);flex-shrink:0;}
.badge b{font-size:13.5px;font-weight:600;display:block;}
.badge span{font-size:11.5px;color:var(--t3);font-family:var(--mono);}

/* final cta */
.cta{padding:110px 0;text-align:center;}
.cta-inner{position:relative;border:1px solid var(--line-2);border-radius:28px;padding:72px 40px;overflow:hidden;
  background:radial-gradient(ellipse 70% 120% at 50% 0%,rgba(123,140,255,.16),transparent 60%),var(--panel);}
.cta h2{font-size:clamp(32px,4.5vw,52px);font-weight:800;letter-spacing:-.03em;margin-bottom:16px;}
.cta p{color:var(--t2);font-size:17px;margin-bottom:34px;}
.cta .hero-cta{justify-content:center;}

/* footer */
footer{border-top:1px solid var(--line);padding:54px 0 40px;position:relative;z-index:1;}
.foot-grid{display:flex;justify-content:space-between;gap:40px;flex-wrap:wrap;margin-bottom:36px;}
.foot-col h5{font-family:var(--mono);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--t3);margin-bottom:16px;}
.foot-col a{display:block;color:var(--t2);font-size:14px;margin-bottom:10px;transition:color .2s;}
.foot-col a:hover{color:var(--t1);}
.foot-bot{display:flex;justify-content:space-between;align-items:center;padding-top:26px;border-top:1px solid var(--line);font-size:13px;color:var(--t3);flex-wrap:wrap;gap:12px;}
</style>
<div class="grid-bg"></div>

<nav id="nav">
  <div class="wrap nav-in">
    <div class="logo"><span class="logo-mark"></span> Ex-Layer</div>
    <div class="nav-links">
      <a href="#how">Platform</a>
      <a href="#how">How it works</a>
      <a href="#integrations">Integrations</a>
      <a href="#security">Security</a>
      <a href="#demo" class="btn btn-pri">Book a demo</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="wrap hero-grid">
    <div>
      <div class="eyebrow reveal"><span class="pulse"></span> AI Remediation Engine</div>
      <h1 class="reveal d1">The execution layer for <em>remediation.</em></h1>
      <p class="sub reveal d2">Ex-Layer connects to any scanner and intelligently closes security issues at scale — with full context of your environment. Patch, script, or uninstall, with approvals and rollout built in.</p>
      <div class="hero-cta reveal d3">
        <a href="#demo" class="btn btn-pri">Book a demo →</a>
        <a href="#engine" class="btn btn-ghost">See the engine run</a>
      </div>
      <div class="hero-note reveal d4">Trusted across <b>SecOps, Tenable, Qualys, Defender, CrowdStrike</b> &amp; more</div>
    </div>
    <div class="reveal d2">
      <div class="term">
        <div class="term-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="term-title">remediation-engine — live</span>
          <span class="term-live"><span class="d"></span>WORKING</span>
        </div>
        <div class="term-body" id="termBody"></div>
        <div class="term-foot"><span>engine</span><span class="rail"><i id="termRail"></i></span><span id="termPct">0%</span></div>
      </div>
    </div>
  </div>
</header>

<!-- TRUST -->
<section class="trust" id="integrations">
  <div class="wrap">
    <div class="trust-lbl reveal">Connects to every scanner you already run</div>
    <div class="logos">
      <div class="logo-pill reveal"><span class="lm" style="background:linear-gradient(135deg,#9ba8ff,#7b8cff)">S</span><span>SecOps</span></div>
      <div class="logo-pill reveal"><span class="lm" style="background:linear-gradient(135deg,#60a5fa,#3b82f6)">T</span><span>Tenable</span></div>
      <div class="logo-pill reveal"><span class="lm" style="background:linear-gradient(135deg,#34d399,#10b981)">D</span><span>Microsoft Defender VM</span></div>
      <div class="logo-pill reveal d1"><span class="lm" style="background:linear-gradient(135deg,#f87171,#ef4444)">Q</span><span>Qualys</span></div>
      <div class="logo-pill reveal d1"><span class="lm" style="background:linear-gradient(135deg,#fb923c,#f97316)">R</span><span>Rapid7</span></div>
      <div class="logo-pill reveal d2"><span class="lm" style="background:linear-gradient(135deg,#a78bfa,#8b5cf6)">C</span><span>CrowdStrike Falcon</span></div>
      <div class="logo-pill reveal d2"><span class="lm" style="background:linear-gradient(135deg,#fbbf24,#f59e0b)">P</span><span>Palo Alto Cortex</span></div>
      <div class="logo-pill reveal d3"><span class="lm" style="background:linear-gradient(135deg,#22d3ee,#06b6d4)">Z</span><span>Zscaler Risk360</span></div>
    </div>
  </div>
</section>

<!-- PROBLEM STATS -->
<section class="stats">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-eyebrow reveal">The remediation gap</div>
      <h2 class="sec-title reveal d1">Scanners find. Backlogs grow.</h2>
      <p class="sec-sub reveal d2">Every tool surfaces more findings than any team can fix. Exposures pile up, duplicates multiply, and the window attackers need stays open.</p>
    </div>
    <div class="stat-grid">
      <div class="stat reveal">
        <div class="num"><span class="cu" data-to="67">0</span><span>%</span></div>
        <div class="lbl">of breaches trace back to a known, unpatched vulnerability that a scanner had already flagged.</div>
      </div>
      <div class="stat s2 reveal d1">
        <div class="num"><span class="cu" data-to="38">0</span><span> days</span></div>
        <div class="lbl">average mean-time-to-remediate for critical exposures — far wider than the exploit window.</div>
      </div>
      <div class="stat s3 reveal d2">
        <div class="num"><span class="cu" data-to="3" data-suffix=".2">0</span><span>×</span></div>
        <div class="lbl">duplicate findings across overlapping scanners, inflating the backlog with noise.</div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how" id="how">
  <div class="wrap">
    <div class="sec-head">
      <div class="sec-eyebrow reveal">How it works</div>
      <h2 class="sec-title reveal d1">From found to fixed — autonomously.</h2>
      <p class="sec-sub reveal d2">One pipeline turns raw scanner output into executed remediation, with a human in the loop exactly where you want one.</p>
    </div>
    <div class="steps">
