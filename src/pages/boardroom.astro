---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Ex-Layer — The AI Remediation Execution Layer" themeColor="#f4f6fb" fontHref={"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"}>
<style is:inline slot="head">
:root{
  --bg:#f4f6fb; --surface:#ffffff; --ink:#0b1020; --ink-2:#3a425c; --ink-3:#737d99;
  --line:#e4e8f2; --line-2:#d3d9e8;
  --cobalt:#1d4ed8; --cobalt-2:#2563eb; --cobalt-soft:#eef2ff;
  --green:#0e9f6e; --green-soft:#e7f7f0; --amber:#d97706; --rose:#e11d48;
  --sans:'Inter',sans-serif; --disp:'Space Grotesk',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:var(--sans);background:var(--bg);color:var(--ink);overflow-x:hidden;line-height:1.55;
  background:radial-gradient(ellipse 70% 50% at 85% -5%,rgba(29,78,216,.08),transparent 55%),
    radial-gradient(ellipse 50% 40% at 5% 10%,rgba(14,159,110,.06),transparent 55%),var(--bg);}
::selection{background:rgba(29,78,216,.16);}
a{color:inherit;text-decoration:none;}
.wrap{max-width:1180px;margin:0 auto;padding:0 32px;}
.disp{font-family:var(--disp);}

nav{position:fixed;top:0;left:0;right:0;z-index:50;transition:background .3s,border-color .3s,box-shadow .3s;border-bottom:1px solid transparent;}
nav.scrolled{background:rgba(255,255,255,.82);backdrop-filter:blur(14px);border-bottom-color:var(--line);box-shadow:0 6px 24px -16px rgba(11,16,32,.3);}
.nav-in{display:flex;align-items:center;justify-content:space-between;height:70px;}
.logo{display:flex;align-items:center;gap:10px;font-family:var(--disp);font-weight:700;font-size:19px;letter-spacing:-.02em;}
.logo-mark{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--cobalt-2),var(--cobalt));position:relative;box-shadow:0 4px 12px -2px rgba(29,78,216,.5);}
.logo-mark::before{content:'';position:absolute;inset:6px;border:1.5px solid #fff;border-radius:3px;opacity:.9;}
.logo-mark::after{content:'';position:absolute;top:9px;left:9px;width:12px;height:12px;border-radius:2px;background:#fff;}
.nav-links{display:flex;align-items:center;gap:34px;}
.nav-links a{font-size:14px;font-weight:500;color:var(--ink-2);transition:color .2s;}
.nav-links a:hover{color:var(--ink);}
@media(max-width:820px){.nav-links a:not(.btn){display:none;}}
.btn{display:inline-flex;align-items:center;gap:8px;font-family:var(--sans);font-weight:600;font-size:14px;cursor:pointer;border:none;transition:transform .15s cubic-bezier(.16,1,.3,1),box-shadow .2s,background .2s;}
.btn-pri{background:var(--cobalt);color:#fff;padding:11px 20px;border-radius:9px;box-shadow:0 8px 22px -8px rgba(29,78,216,.6);}
.btn-pri:hover{transform:translateY(-2px);background:var(--cobalt-2);box-shadow:0 14px 30px -8px rgba(29,78,216,.6);}
.btn-ghost{background:var(--surface);color:var(--ink);padding:11px 20px;border-radius:9px;border:1px solid var(--line-2);}
.btn-ghost:hover{transform:translateY(-2px);border-color:var(--cobalt);color:var(--cobalt);}

/* hero */
.hero{padding:160px 0 80px;}
.eyebrow{display:inline-flex;align-items:center;gap:9px;font-family:var(--disp);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--cobalt);background:var(--cobalt-soft);border:1px solid #dbe3ff;padding:7px 14px;border-radius:999px;margin-bottom:26px;font-weight:600;}
.eyebrow .pulse{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 0 0 rgba(14,159,110,.5);animation:ping 2.2s infinite;}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(14,159,110,.45);}70%{box-shadow:0 0 0 8px rgba(14,159,110,0);}100%{box-shadow:0 0 0 0 rgba(14,159,110,0);}}
h1{font-family:var(--disp);font-size:clamp(42px,6vw,76px);font-weight:700;letter-spacing:-.04em;line-height:1.02;margin-bottom:22px;max-width:14ch;}
h1 em{font-style:normal;color:var(--cobalt);}
.sub{font-size:19px;color:var(--ink-2);line-height:1.6;max-width:600px;margin-bottom:34px;}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;align-items:center;}
.hero-stats{display:flex;gap:40px;margin-top:48px;flex-wrap:wrap;}
.hero-stat .n{font-family:var(--disp);font-size:34px;font-weight:700;letter-spacing:-.03em;color:var(--ink);font-feature-settings:"tnum";}
.hero-stat .n em{font-style:normal;color:var(--green);}
.hero-stat .l{font-size:13px;color:var(--ink-3);margin-top:4px;}
.hero-stat+.hero-stat{padding-left:40px;border-left:1px solid var(--line-2);}

/* reveal */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .75s cubic-bezier(.16,1,.3,1),transform .75s cubic-bezier(.16,1,.3,1);}
.reveal.in{opacity:1;transform:none;}
.reveal.d1{transition-delay:.08s;}.reveal.d2{transition-delay:.16s;}.reveal.d3{transition-delay:.24s;}.reveal.d4{transition-delay:.32s;}

section{position:relative;}
.sec-head{max-width:680px;margin:0 0 52px;}
.sec-head.center{margin-left:auto;margin-right:auto;text-align:center;}
.sec-eyebrow{font-family:var(--disp);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--cobalt);margin-bottom:14px;font-weight:600;}
.sec-title{font-family:var(--disp);font-size:clamp(30px,4vw,48px);font-weight:700;letter-spacing:-.03em;line-height:1.08;margin-bottom:16px;}
.sec-sub{color:var(--ink-2);font-size:17px;line-height:1.6;}

/* trust */
.trust{padding:50px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.5);}
.trust-lbl{text-align:center;font-size:13px;color:var(--ink-3);margin-bottom:26px;font-weight:500;}
.logos{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;}
.logo-pill{display:inline-flex;align-items:center;gap:9px;border:1px solid var(--line);border-radius:11px;padding:10px 15px;background:var(--surface);transition:border-color .25s,transform .25s,box-shadow .25s;}
.logo-pill:hover{transform:translateY(-3px);border-color:var(--line-2);box-shadow:0 12px 24px -16px rgba(11,16,32,.35);}
.logo-pill .lm{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:var(--disp);font-weight:600;font-size:11px;color:#fff;}
.logo-pill span{font-size:13.5px;font-weight:600;color:var(--ink-2);white-space:nowrap;}

/* problem */
.problem{padding:100px 0;}
.prob-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;margin-top:8px;}
@media(max-width:820px){.prob-grid{grid-template-columns:1fr;}}
.prob{background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:32px 28px;transition:transform .3s,box-shadow .3s;}
.prob:hover{transform:translateY(-4px);box-shadow:0 24px 50px -28px rgba(11,16,32,.3);}
.prob .big{font-family:var(--disp);font-size:60px;font-weight:700;letter-spacing:-.03em;line-height:1;color:var(--rose);font-feature-settings:"tnum";}
.prob.p2 .big{color:var(--amber);}.prob.p3 .big{color:var(--cobalt);}
.prob .big sup{font-size:30px;}
.prob p{color:var(--ink-2);font-size:14.5px;line-height:1.55;margin-top:14px;}

/* pipeline */
.pipe{padding:100px 0;}
.flow{position:relative;margin-top:20px;}
.flow-track{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;}
@media(max-width:860px){.flow-track{grid-template-columns:1fr;gap:18px;}}
.flow-svg{position:absolute;top:46px;left:0;width:100%;height:4px;z-index:0;}
@media(max-width:860px){.flow-svg{display:none;}}
.node{position:relative;z-index:1;padding:0 18px;text-align:center;}
.node .dot{width:64px;height:64px;border-radius:18px;background:var(--surface);border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;color:var(--cobalt);box-shadow:0 10px 30px -16px rgba(29,78,216,.4);transition:transform .3s,box-shadow .3s;}
.node:hover .dot{transform:translateY(-5px) scale(1.04);box-shadow:0 18px 40px -16px rgba(29,78,216,.55);}
.node .step-n{font-family:var(--disp);font-size:12px;font-weight:600;color:var(--cobalt);letter-spacing:.1em;margin-bottom:8px;}
.node h3{font-family:var(--disp);font-size:19px;font-weight:600;letter-spacing:-.01em;margin-bottom:8px;}
.node p{color:var(--ink-2);font-size:13.5px;line-height:1.55;max-width:230px;margin:0 auto;}

/* engine split */
.engine{padding:100px 0;}
.eng-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:60px;align-items:center;}
@media(max-width:920px){.eng-grid{grid-template-columns:1fr;gap:44px;}}
.eng-list{margin-top:26px;display:flex;flex-direction:column;gap:8px;}
.eng-item{display:flex;gap:14px;padding:16px;border-radius:12px;transition:background .25s;}
.eng-item:hover{background:var(--surface);}
.eng-item .ck{width:26px;height:26px;border-radius:8px;background:var(--green-soft);display:flex;align-items:center;justify-content:center;color:var(--green);flex-shrink:0;}
.eng-item h4{font-family:var(--disp);font-size:16px;font-weight:600;margin-bottom:3px;}
.eng-item p{color:var(--ink-2);font-size:14px;line-height:1.55;}
.camp{background:var(--surface);border:1px solid var(--line);border-radius:18px;overflow:hidden;box-shadow:0 40px 80px -40px rgba(11,16,32,.4);}
.camp-top{padding:22px 24px;border-bottom:1px solid var(--line);}
.camp-chips{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.chip{font-family:var(--disp);font-size:10px;font-weight:600;letter-spacing:.04em;padding:5px 10px;border-radius:7px;}
.chip.crit{color:var(--rose);background:#fff1f3;}.chip.kev{color:var(--amber);background:#fef6ec;}.chip.act{color:var(--cobalt);background:var(--cobalt-soft);}
.camp-title{font-family:var(--disp);font-size:17px;font-weight:600;letter-spacing:-.01em;}
.camp-rows{padding:8px 24px 14px;}
.crow{display:flex;justify-content:space-between;padding:13px 0;border-top:1px solid var(--line);font-size:14px;color:var(--ink-2);}
.crow:first-child{border-top:none;}
.crow .v{font-weight:600;color:var(--ink);}
.crow .v.ok{color:var(--green);}
.camp-foot{padding:16px 24px;border-top:1px solid var(--line);display:flex;gap:10px;}
.camp-foot .b1{flex:1;text-align:center;background:var(--cobalt);color:#fff;font-weight:600;font-size:14px;padding:11px;border-radius:9px;}
.camp-foot .b2{text-align:center;color:var(--ink-2);font-size:14px;padding:11px 18px;border-radius:9px;border:1px solid var(--line-2);}

/* outcomes - giant numbers */
.outcomes{padding:110px 0;background:var(--ink);color:#fff;border-radius:36px;margin:0 16px;}
.outcomes .wrap{padding:0 32px;}
.outcomes .sec-title{color:#fff;}
.outcomes .sec-eyebrow{color:#8aa0ff;}
.out-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:48px;}
@media(max-width:820px){.out-grid{grid-template-columns:repeat(2,1fr);}}
.out{text-align:left;border-left:2px solid rgba(255,255,255,.14);padding-left:22px;}
.out .num{font-family:var(--disp);font-size:clamp(48px,6vw,76px);font-weight:700;letter-spacing:-.04em;line-height:1;font-feature-settings:"tnum";color:#fff;}
.out .num em{font-style:normal;color:#5eead4;}
.out .lbl{color:rgba(255,255,255,.6);font-size:14px;margin-top:12px;}

/* security */
.sec-strip{padding:100px 0;}
.badges{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:14px;}
@media(max-width:820px){.badges{grid-template-columns:1fr 1fr;}}
.badge{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:24px 20px;transition:transform .3s,box-shadow .3s;}
.badge:hover{transform:translateY(-4px);box-shadow:0 20px 44px -26px rgba(11,16,32,.3);}
.badge .ic{width:40px;height:40px;border-radius:11px;background:var(--cobalt-soft);display:flex;align-items:center;justify-content:center;color:var(--cobalt);margin-bottom:16px;}
.badge b{font-family:var(--disp);font-size:15px;font-weight:600;display:block;margin-bottom:3px;}
.badge span{font-size:13px;color:var(--ink-3);}

/* cta */
.cta{padding:120px 0;}
.cta-inner{background:linear-gradient(135deg,var(--cobalt),#3b5bdb);border-radius:30px;padding:80px 40px;text-align:center;color:#fff;position:relative;overflow:hidden;}
.cta-inner::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 100% at 50% 0%,rgba(255,255,255,.18),transparent 60%);}
.cta-inner>*{position:relative;}
.cta h2{font-family:var(--disp);font-size:clamp(32px,4.5vw,54px);font-weight:700;letter-spacing:-.03em;margin-bottom:16px;}
.cta p{font-size:18px;opacity:.92;margin-bottom:34px;}
.cta .btn-pri{background:#fff;color:var(--cobalt);}
.cta .btn-pri:hover{background:#eef2ff;}
.cta .btn-ghost{background:transparent;color:#fff;border-color:rgba(255,255,255,.4);}
.cta .btn-ghost:hover{background:rgba(255,255,255,.12);color:#fff;border-color:#fff;}
.cta .hero-cta{justify-content:center;}

/* footer */
footer{border-top:1px solid var(--line);padding:56px 0 40px;}
.foot-grid{display:flex;justify-content:space-between;gap:40px;flex-wrap:wrap;margin-bottom:36px;}
.foot-col h5{font-family:var(--disp);font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-3);margin-bottom:16px;font-weight:600;}
.foot-col a{display:block;color:var(--ink-2);font-size:14px;margin-bottom:10px;transition:color .2s;}
.foot-col a:hover{color:var(--cobalt);}
.foot-bot{display:flex;justify-content:space-between;align-items:center;padding-top:26px;border-top:1px solid var(--line);font-size:13px;color:var(--ink-3);flex-wrap:wrap;gap:12px;}
</style>

<nav id="nav">
  <div class="wrap nav-in">
    <div class="logo"><span class="logo-mark"></span> Ex-Layer</div>
    <div class="nav-links">
      <a href="#how">Platform</a>
      <a href="#how">How it works</a>
      <a href="#integrations">Integrations</a>
      <a href="#security">Security</a>
      <a href="#demo" class="btn btn-pri">Book a demo</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="wrap">
    <div class="eyebrow reveal"><span class="pulse"></span> AI Remediation Engine</div>
    <h1 class="reveal d1">The execution layer for <em>remediation.</em></h1>
    <p class="sub reveal d2">Ex-Layer connects to any scanner and intelligently closes security issues at scale — with full context of your environment. Patch, script, or uninstall, with approvals and rollout built in.</p>
    <div class="hero-cta reveal d3">
      <a href="#demo" class="btn btn-pri">Book a demo →</a>
      <a href="#engine" class="btn btn-ghost">See how it works</a>
    </div>
    <div class="hero-stats reveal d4">
      <div class="hero-stat"><div class="n"><em>90%</em></div><div class="l">faster mean-time-to-remediate</div></div>
      <div class="hero-stat"><div class="n">8</div><div class="l">scanners unified in one graph</div></div>
      <div class="hero-stat"><div class="n">100%</div><div class="l">auditable, governed actions</div></div>
    </div>
  </div>
</header>

<!-- TRUST -->
<section class="trust" id="integrations">
  <div class="wrap">
    <div class="trust-lbl reveal">Connects to every scanner you already run</div>
    <div class="logos">
      <div class="logo-pill reveal"><span class="lm" style="background:linear-gradient(135deg,#3b82f6,#1d4ed8)">S</span><span>SecOps</span></div>
      <div class="logo-pill reveal"><span class="lm" style="background:linear-gradient(135deg,#2563eb,#1e40af)">T</span><span>Tenable</span></div>
      <div class="logo-pill reveal d1"><span class="lm" style="background:linear-gradient(135deg,#10b981,#059669)">D</span><span>Microsoft Defender VM</span></div>
      <div class="logo-pill reveal d1"><span class="lm" style="background:linear-gradient(135deg,#ef4444,#b91c1c)">Q</span><span>Qualys</span></div>
      <div class="logo-pill reveal d2"><span class="lm" style="background:linear-gradient(135deg,#f97316,#c2410c)">R</span><span>Rapid7</span></div>
      <div class="logo-pill reveal d2"><span class="lm" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9)">C</span><span>CrowdStrike Falcon</span></div>
      <div class="logo-pill reveal d3"><span class="lm" style="background:linear-gradient(135deg,#f59e0b,#b45309)">P</span><span>Palo Alto Cortex</span></div>
      <div class="logo-pill reveal d3"><span class="lm" style="background:linear-gradient(135deg,#06b6d4,#0e7490)">Z</span><span>Zscaler Risk360</span></div>
    </div>
  </div>
</section>

<!-- PROBLEM -->
<section class="problem">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-eyebrow">The remediation gap</div>
      <h2 class="sec-title">Scanners find. Backlogs grow.</h2>
      <p class="sec-sub">Every tool surfaces more findings than any team can fix. Exposures pile up, duplicates multiply, and the exploit window stays open.</p>
    </div>
    <div class="prob-grid">
      <div class="prob reveal"><div class="big"><span class="cu" data-to="67">0</span><sup>%</sup></div><p>of breaches trace back to a known, unpatched vulnerability a scanner had already flagged.</p></div>
      <div class="prob p2 reveal d1"><div class="big"><span class="cu" data-to="38">0</span><sup> days</sup></div><p>average MTTR for critical exposures — far wider than the exploit window.</p></div>
      <div class="prob p3 reveal d2"><div class="big"><span class="cu" data-to="3" data-suffix=".2">0</span><sup>×</sup></div><p>duplicate findings across overlapping scanners, inflating the backlog with noise.</p></div>
    </div>
  </div>
</section>

<!-- PIPELINE -->
<section class="pipe" id="how">
  <div class="wrap">
    <div class="sec-head center reveal">
      <div class="sec-eyebrow">How it works</div>
      <h2 class="sec-title">From found to fixed — autonomously.</h2>
      <p class="sec-sub">One governed pipeline turns raw scanner output into executed remediation.</p>
    </div>
    <div class="flow">
      <svg class="flow-svg" preserveAspectRatio="none" viewBox="0 0 1000 4">
        <line x1="0" y1="2" x2="1000" y2="2" stroke="#d3d9e8" stroke-width="2"/>
        <line id="flowLine" x1="0" y1="2" x2="1000" y2="2" stroke="#1d4ed8" stroke-width="2" stroke-dasharray="1000" stroke-dashoffset="1000"/>
      </svg>
      <div class="flow-track">
        <div class="node reveal"><div class="dot"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v10"/><polyline points="8 9 12 13 16 9"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg></div><div class="step-n">STEP 01</div><h3>Ingest</h3><p>Connect every scanner and EDR into one normalized exposure graph.</p></div>
        <div class="node reveal d1"><div class="dot"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="18" r="3"/><path d="M9 6h6a3 3 0 0 1 3 3v6"/><path d="M6 9v6a3 3 0 0 0 3 3h6"/></svg></div><div class="step-n">STEP 02</div><h3>Correlate</h3><p>De-duplicate across sources, enrich with CISA-KEV &amp; exploit intel.</p></div>
        <div class="node reveal d2"><div class="dot"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="14" y2="12"/><line x1="4" y1="18" x2="9" y2="18"/></svg></div><div class="step-n">STEP 03</div><h3>Prioritize</h3><p>Rank by real, exploited risk in your environment — not raw CVSS.</p></div>
        <div class="node reveal d3"><div class="dot"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><div class="step-n">STEP 04</div><h3>Remediate</h3><p>Auto-drafted campaigns with approvals, pilot rings &amp; rollout.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- ENGINE -->
<section class="engine" id="engine">
  <div class="wrap eng-grid">
    <div>
      <div class="sec-eyebrow reveal">The engine</div>
      <h2 class="sec-title reveal d1">An engine that reasons, then acts.</h2>
      <p class="sec-sub reveal d2">It resolves intent, targets the fleet, and assembles a campaign — then you approve, pilot, and roll out. Every action governed and auditable.</p>
      <div class="eng-list">
        <div class="eng-item reveal d2"><span class="ck"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><div><h4>Drafts the fix automatically</h4><p>Patch deployment, remediation scripts, or software uninstall — chosen per finding.</p></div></div>
        <div class="eng-item reveal d3"><span class="ck"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><div><h4>Approvals &amp; pilot rings</h4><p>Gate execution behind review, validate on a pilot ring, then promote to the fleet.</p></div></div>
