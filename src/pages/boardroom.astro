<script is:inline>
const nav=document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>20));
const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.15});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
function countUp(el){const to=parseFloat(el.dataset.to),suf=el.dataset.suffix||'',dur=1500,t0=performance.now();
  function tick(t){let p=Math.min((t-t0)/dur,1);p=1-Math.pow(1-p,3);let v=to*p;el.textContent=(suf?v.toFixed(1):Math.round(v));
    if(p<1)requestAnimationFrame(tick);else el.textContent=(suf?to.toFixed(1):to);}requestAnimationFrame(tick);}
const cuio=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){countUp(e.target);cuio.unobserve(e.target);}})},{threshold:.6});
document.querySelectorAll('.cu').forEach(el=>cuio.observe(el));
// animate pipeline line draw
const fl=document.getElementById('flowLine');
const flio=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){fl.style.transition='stroke-dashoffset 1.6s cubic-bezier(.16,1,.3,1)';fl.style.strokeDashoffset='0';flio.unobserve(e.target);}})},{threshold:.4});
flio.observe(document.querySelector('.flow'));
</script>
