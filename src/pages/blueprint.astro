---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Ex-Layer — The AI Remediation Execution Layer" themeColor="#080b11" fontHref={"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"}>
<style is:inline slot="head">
:root{
  --bg:#080b11; --panel:#0c1119; --panel-2:#0f1620; --line:rgba(56,189,248,.14); --line-2:rgba(56,189,248,.28);
  --cyan:#38bdf8; --cyan-br:#7dd3fc; --teal:#22d3ee; --ind:#818cf8; --grid:rgba(56,189,248,.07);
  --em:#34d399; --amber:#fbbf24; --rose:#fb7185;
  --t1:#e6f0f7; --t2:#90a4b8; --t3:#536074;
  --mono:'IBM Plex Mono',monospace; --disp:'Space Grotesk',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:var(--disp);background:var(--bg);color:var(--t1);overflow-x:hidden;line-height:1.55;}
::selection{background:rgba(56,189,248,.25);}
a{color:inherit;text-decoration:none;}
.wrap{max-width:1180px;margin:0 auto;padding:0 32px;}
.mono{font-family:var(--mono);}
.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(var(--grid) 1px,transparent 1px),linear-gradient(90deg,var(--grid) 1px,transparent 1px);
  background-size:40px 40px;-webkit-mask-image:radial-gradient(ellipse 100% 80% at 50% 0%,#000 40%,transparent 85%);
  mask-image:radial-gradient(ellipse 100% 80% at 50% 0%,#000 40%,transparent 85%);}

nav{position:fixed;top:0;left:0;right:0;z-index:50;transition:background .3s,border-color .3s;border-bottom:1px solid transparent;}
nav.scrolled{background:rgba(8,11,17,.78);backdrop-filter:blur(14px);border-bottom-color:var(--line);}
.nav-in{display:flex;align-items:center;justify-content:space-between;height:68px;}
.logo{display:flex;align-items:center;gap:10px;font-weight:700;font-size:18px;letter-spacing:-.02em;}
.logo-mark{width:30px;height:30px;border-radius:7px;border:1.5px solid var(--cyan);position:relative;box-shadow:0 0 18px rgba(56,189,248,.4);display:flex;align-items:center;justify-content:center;}
.logo-mark::after{content:'';width:12px;height:12px;border:1.5px solid var(--cyan);border-radius:2px;}
.nav-links{display:flex;align-items:center;gap:32px;}
.nav-links a{font-family:var(--mono);font-size:13px;color:var(--t2);transition:color .2s;}
.nav-links a:hover{color:var(--cyan-br);}
@media(max-width:820px){.nav-links a:not(.btn){display:none;}}
.btn{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-weight:500;font-size:13px;cursor:pointer;border:none;transition:transform .15s cubic-bezier(.16,1,.3,1),box-shadow .2s,background .2s;}
.btn-pri{background:var(--cyan);color:#04121c;padding:11px 20px;border-radius:8px;box-shadow:0 0 24px -4px rgba(56,189,248,.55);font-weight:600;}
.btn-pri:hover{transform:translateY(-2px);background:var(--cyan-br);box-shadow:0 0 34px -2px rgba(56,189,248,.7);}
.btn-ghost{background:transparent;color:var(--cyan-br);padding:11px 20px;border-radius:8px;border:1px solid var(--line-2);}
.btn-ghost:hover{background:rgba(56,189,248,.08);transform:translateY(-2px);}

/* hero */
.hero{position:relative;z-index:1;padding:140px 0 70px;text-align:center;}
.eyebrow{display:inline-flex;align-items:center;gap:9px;font-family:var(--mono);font-size:11.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan-br);border:1px solid var(--line-2);padding:7px 14px;border-radius:6px;margin-bottom:26px;}
.eyebrow .pulse{width:6px;height:6px;border-radius:50%;background:var(--em);box-shadow:0 0 0 0 rgba(52,211,153,.5);animation:ping 2.2s infinite;}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(52,211,153,.5);}70%{box-shadow:0 0 0 8px rgba(52,211,153,0);}100%{box-shadow:0 0 0 0 rgba(52,211,153,0);}}
h1{font-family:var(--disp);font-size:clamp(40px,5.8vw,72px);font-weight:700;letter-spacing:-.035em;line-height:1.03;margin-bottom:22px;}
h1 em{font-style:normal;color:var(--cyan);text-shadow:0 0 40px rgba(56,189,248,.5);}
.sub{font-size:18px;color:var(--t2);line-height:1.6;max-width:620px;margin:0 auto 32px;}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;align-items:center;justify-content:center;}

/* schematic */
.schematic{margin-top:60px;position:relative;z-index:1;}
.canvas{border:1px solid var(--line-2);border-radius:14px;background:linear-gradient(180deg,var(--panel),rgba(8,11,17,.6));padding:20px;position:relative;overflow:hidden;box-shadow:0 40px 90px -40px rgba(0,0,0,.9);}
.canvas .corner{position:absolute;width:14px;height:14px;border-color:var(--cyan);opacity:.6;}
.canvas .corner.tl{top:8px;left:8px;border-top:1.5px solid;border-left:1.5px solid;}
.canvas .corner.tr{top:8px;right:8px;border-top:1.5px solid;border-right:1.5px solid;}
.canvas .corner.bl{bottom:8px;left:8px;border-bottom:1.5px solid;border-left:1.5px solid;}
.canvas .corner.br{bottom:8px;right:8px;border-bottom:1.5px solid;border-right:1.5px solid;}
.canvas-lbl{position:absolute;top:14px;left:50%;transform:translateX(-50%);font-family:var(--mono);font-size:10px;letter-spacing:.2em;color:var(--t3);text-transform:uppercase;}
.schem-svg{width:100%;height:auto;display:block;}
.flowpath{fill:none;stroke:var(--line-2);stroke-width:1.5;stroke-dasharray:600;stroke-dashoffset:600;animation:draw 1.4s cubic-bezier(.16,1,.3,1) forwards;}
@keyframes draw{to{stroke-dashoffset:0;}}
.node-rect{fill:var(--panel-2);stroke:var(--line-2);stroke-width:1.2;}
.node-rect.engine{fill:rgba(56,189,248,.08);stroke:var(--cyan);}
.node-text{font-family:'IBM Plex Mono',monospace;font-size:11px;fill:var(--t1);}
.node-sub{font-family:'IBM Plex Mono',monospace;font-size:8.5px;fill:var(--t3);letter-spacing:.08em;}
.engine-title{font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:600;fill:var(--cyan-br);}
.packet{fill:var(--cyan);filter:drop-shadow(0 0 4px var(--cyan));}
.packet.em{fill:var(--em);filter:drop-shadow(0 0 4px var(--em));}
.col-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.18em;fill:var(--t3);}
.camp-title{font-size:10px;}
/* campaign nodes flip to "remediated" (green) one by one, then loop */
.camp-rect{transition:stroke .45s cubic-bezier(.16,1,.3,1),fill .45s cubic-bezier(.16,1,.3,1);}
.camp .node-text{transition:fill .45s cubic-bezier(.16,1,.3,1);}
.camp.remediated .camp-rect{stroke:var(--em);fill:rgba(52,211,153,.07);}
.camp.remediated .node-text{fill:var(--em);}
.rem-badge{opacity:0;transform:scale(.4);transform-box:fill-box;transform-origin:center;
  transition:opacity .4s cubic-bezier(.16,1,.3,1),transform .4s cubic-bezier(.16,1,.3,1);}
.camp.remediated .rem-badge{opacity:1;transform:scale(1);}
.rem-badge circle{fill:var(--em);stroke:none;filter:drop-shadow(0 0 5px rgba(52,211,153,.6));}
.rem-badge path{fill:none;stroke:#04121c;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

/* reveal */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1);}
.reveal.in{opacity:1;transform:none;}
.reveal.d1{transition-delay:.08s;}.reveal.d2{transition-delay:.16s;}.reveal.d3{transition-delay:.24s;}.reveal.d4{transition-delay:.32s;}

section{position:relative;z-index:1;}
.sec-head{max-width:680px;margin:0 auto 50px;text-align:center;}
.sec-eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan-br);margin-bottom:14px;}
.sec-eyebrow::before{content:'// ';color:var(--t3);}
.sec-title{font-family:var(--disp);font-size:clamp(28px,3.8vw,44px);font-weight:700;letter-spacing:-.03em;line-height:1.1;margin-bottom:16px;}
.sec-sub{color:var(--t2);font-size:16px;line-height:1.6;}

/* trust */
.trust{padding:50px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.trust-lbl{text-align:center;font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--t3);margin-bottom:26px;}
.logos{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;}
.logo-pill{display:inline-flex;align-items:center;gap:9px;border:1px solid var(--line);border-radius:8px;padding:10px 15px;background:var(--panel);transition:border-color .25s,transform .25s;}
.logo-pill:hover{border-color:var(--line-2);transform:translateY(-3px);}
.logo-pill .lm{width:24px;height:24px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:600;font-size:11px;color:#04121c;}
.logo-pill span{font-family:var(--mono);font-size:12.5px;color:var(--t2);white-space:nowrap;}

/* spec sheet sections */
.spec{padding:90px 0;}
.spec-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;border:1px solid var(--line);border-radius:14px;overflow:hidden;}
@media(max-width:820px){.spec-grid{grid-template-columns:1fr;}}
.spec-cell{padding:34px 30px;border-right:1px solid var(--line);position:relative;}
.spec-cell:last-child{border-right:none;}
@media(max-width:820px){.spec-cell{border-right:none;border-bottom:1px solid var(--line);}}
.spec-cell .k{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--t3);text-transform:uppercase;margin-bottom:18px;}
.spec-cell .big{font-family:var(--disp);font-size:56px;font-weight:700;letter-spacing:-.03em;line-height:1;color:var(--rose);font-feature-settings:"tnum";}
.spec-cell.c2 .big{color:var(--amber);}.spec-cell.c3 .big{color:var(--cyan);}
.spec-cell .big sup{font-size:26px;}
.spec-cell p{color:var(--t2);font-size:13.5px;line-height:1.55;margin-top:14px;}

/* steps */
.steps-wrap{padding:90px 0;}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
@media(max-width:980px){.steps{grid-template-columns:repeat(2,1fr);}}
@media(max-width:560px){.steps{grid-template-columns:1fr;}}
.step{border:1px solid var(--line);border-radius:12px;padding:26px 22px;background:var(--panel);transition:border-color .3s,transform .3s,box-shadow .3s;position:relative;}
.step::before{content:'';position:absolute;top:0;left:22px;width:30px;height:2px;background:var(--cyan);box-shadow:0 0 10px var(--cyan);}
.step:hover{border-color:var(--line-2);transform:translateY(-5px);box-shadow:0 24px 50px -30px rgba(56,189,248,.5);}
.step .n{font-family:var(--mono);font-size:11px;color:var(--cyan-br);margin:14px 0 16px;}
.step .ic{width:44px;height:44px;border-radius:10px;border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;margin-bottom:16px;color:var(--cyan);}
.step h3{font-family:var(--disp);font-size:18px;font-weight:600;margin-bottom:9px;}
.step p{color:var(--t2);font-size:13px;line-height:1.55;}

/* engine */
.engine{padding:90px 0;}
.eng-grid{display:grid;grid-template-columns:1fr 1fr;gap:54px;align-items:center;}
@media(max-width:920px){.eng-grid{grid-template-columns:1fr;gap:40px;}}
.eng-list{margin-top:24px;display:flex;flex-direction:column;gap:6px;}
.eng-item{display:flex;gap:14px;padding:14px;border:1px solid transparent;border-radius:10px;transition:border-color .25s,background .25s;}
.eng-item:hover{border-color:var(--line);background:var(--panel);}
.eng-item .ck{width:24px;height:24px;border-radius:6px;border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;color:var(--em);flex-shrink:0;}
.eng-item h4{font-family:var(--disp);font-size:15.5px;font-weight:600;margin-bottom:3px;}
.eng-item p{color:var(--t2);font-size:13.5px;line-height:1.55;}
.term{border:1px solid var(--line-2);border-radius:12px;overflow:hidden;background:rgba(8,11,17,.85);box-shadow:0 30px 70px -34px rgba(0,0,0,.9);}
.term-bar{display:flex;align-items:center;gap:7px;padding:12px 15px;border-bottom:1px solid var(--line);}
.term-bar .d{width:9px;height:9px;border-radius:50%;border:1px solid var(--line-2);}
.term-bar .nm{margin-left:8px;font-family:var(--mono);font-size:10.5px;color:var(--t3);letter-spacing:.08em;}
.term-body{padding:16px 16px;font-family:var(--mono);font-size:12px;line-height:1.9;min-height:180px;}
.tl{display:flex;gap:10px;opacity:0;transform:translateY(4px);}
.tl.show{opacity:1;transform:none;transition:all .3s;}
.tl .tm{color:var(--t3);flex-shrink:0;}.tl .st{color:var(--cyan-br);width:78px;flex-shrink:0;}.tl .ms{color:var(--t2);}
.tk{padding:1px 5px;border-radius:3px;}.tk.c{color:var(--cyan-br);background:rgba(56,189,248,.12);}.tk.k{color:var(--amber);background:rgba(251,191,36,.12);}.tk.o{color:var(--em);background:rgba(52,211,153,.12);}
.caret{display:inline-block;width:7px;height:13px;background:var(--cyan);vertical-align:-2px;animation:blink 1s steps(1) infinite;}
@keyframes blink{50%{opacity:0;}}

/* outcomes */
.outcomes{padding:90px 0;}
.out-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
@media(max-width:820px){.out-grid{grid-template-columns:repeat(2,1fr);}}
.out{border:1px solid var(--line);border-radius:12px;padding:28px 22px;background:var(--panel);}
.out .num{font-family:var(--disp);font-size:clamp(36px,4.5vw,52px);font-weight:700;letter-spacing:-.03em;line-height:1;color:var(--cyan);font-feature-settings:"tnum";}
.out .lbl{color:var(--t2);font-size:13px;margin-top:10px;font-family:var(--mono);}

/* security */
.sec-strip{padding:90px 0;}
.badges{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:14px;}
@media(max-width:820px){.badges{grid-template-columns:1fr 1fr;}}
.badge{border:1px solid var(--line);border-radius:12px;padding:22px 20px;background:var(--panel);transition:transform .3s,border-color .3s;}
.badge:hover{transform:translateY(-4px);border-color:var(--line-2);}
.badge .ic{width:38px;height:38px;border-radius:9px;border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;color:var(--cyan);margin-bottom:14px;}
.badge b{font-family:var(--disp);font-size:14.5px;font-weight:600;display:block;margin-bottom:3px;}
.badge span{font-family:var(--mono);font-size:11px;color:var(--t3);}

/* cta */
.cta{padding:110px 0;text-align:center;}
.cta-inner{border:1px solid var(--line-2);border-radius:20px;padding:70px 40px;position:relative;overflow:hidden;
  background:radial-gradient(ellipse 70% 130% at 50% 0%,rgba(56,189,248,.14),transparent 60%),var(--panel);}
.cta-inner .corner{position:absolute;width:16px;height:16px;border-color:var(--cyan);opacity:.6;}
.cta-inner .tl{top:12px;left:12px;border-top:1.5px solid;border-left:1.5px solid;}
.cta-inner .tr{top:12px;right:12px;border-top:1.5px solid;border-right:1.5px solid;}
.cta-inner .bl{bottom:12px;left:12px;border-bottom:1.5px solid;border-left:1.5px solid;}
.cta-inner .br{bottom:12px;right:12px;border-bottom:1.5px solid;border-right:1.5px solid;}
.cta h2{font-family:var(--disp);font-size:clamp(30px,4.5vw,50px);font-weight:700;letter-spacing:-.03em;margin-bottom:16px;}
.cta p{color:var(--t2);font-size:17px;margin-bottom:32px;}
.cta .hero-cta{justify-content:center;}

footer{border-top:1px solid var(--line);padding:50px 0 38px;position:relative;z-index:1;}
.foot-grid{display:flex;justify-content:space-between;gap:40px;flex-wrap:wrap;margin-bottom:34px;}
.foot-col h5{font-family:var(--mono);font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--t3);margin-bottom:16px;}
.foot-col a{display:block;color:var(--t2);font-size:13.5px;margin-bottom:10px;font-family:var(--mono);transition:color .2s;}
.foot-col a:hover{color:var(--cyan-br);}
.foot-bot{display:flex;justify-content:space-between;align-items:center;padding-top:24px;border-top:1px solid var(--line);font-family:var(--mono);font-size:12px;color:var(--t3);flex-wrap:wrap;gap:12px;}
</style>
<div class="grid-bg"></div>

<nav id="nav">
  <div class="wrap nav-in">
    <div class="logo"><span class="logo-mark"></span> Ex-Layer</div>
    <div class="nav-links">
      <a href="#how">Platform</a><a href="#how">How it works</a><a href="#integrations">Integrations</a><a href="#security">Security</a>
      <a href="#demo" class="btn btn-pri">Book a demo</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="wrap">
    <div class="eyebrow reveal"><span class="pulse"></span> AI Remediation Engine</div>
    <h1 class="reveal d1">The execution layer for <em>remediation.</em></h1>
    <p class="sub reveal d2">Ex-Layer connects to any scanner and intelligently closes security issues at scale — with full context of your environment. Patch, script, or uninstall, with approvals and rollout built in.</p>
    <div class="hero-cta reveal d3">
      <a href="#demo" class="btn btn-pri">Book a demo →</a>
      <a href="#engine" class="btn btn-ghost">View the architecture</a>
    </div>
    <!-- SCHEMATIC -->
    <div class="schematic reveal d2">
      <div class="canvas">
        <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
        <span class="canvas-lbl">EX-LAYER · REMEDIATION EXECUTION PIPELINE</span>
        <svg class="schem-svg" viewBox="0 0 940 430" preserveAspectRatio="xMidYMid meet">
          <!-- column labels -->
          <text class="col-lbl" x="24" y="24">SCANNERS</text>
          <text class="col-lbl" x="708" y="18">REMEDIATION CAMPAIGNS</text>

          <!-- connectors: sources -> engine -->
          <path class="flowpath" d="M176,55 C300,55 300,207 380,207" style="animation-delay:.1s"/>
          <path class="flowpath" d="M176,101 C300,101 305,207 380,207" style="animation-delay:.16s"/>
          <path class="flowpath" d="M176,147 C310,147 330,207 380,207" style="animation-delay:.22s"/>
          <path class="flowpath" d="M176,193 C310,193 345,207 380,207" style="animation-delay:.28s"/>
          <path class="flowpath" d="M176,239 C310,239 345,207 380,207" style="animation-delay:.34s"/>
          <path class="flowpath" d="M176,285 C310,285 330,207 380,207" style="animation-delay:.4s"/>
          <path class="flowpath" d="M176,331 C300,331 305,207 380,207" style="animation-delay:.46s"/>
          <path class="flowpath" d="M176,377 C300,377 300,207 380,207" style="animation-delay:.52s"/>
          <!-- intel -> engine -->
          <path class="flowpath" d="M500,56 L500,132" style="animation-delay:.5s"/>
          <!-- engine -> campaigns -->
          <path class="flowpath" d="M620,207 C680,207 660,55 708,55" style="animation-delay:.7s"/>
          <path class="flowpath" d="M620,207 C680,207 670,123 708,123" style="animation-delay:.75s"/>
          <path class="flowpath" d="M620,207 C690,207 700,191 708,191" style="animation-delay:.8s"/>
          <path class="flowpath" d="M620,207 C690,207 690,259 708,259" style="animation-delay:.85s"/>
          <path class="flowpath" d="M620,207 C680,207 660,327 708,327" style="animation-delay:.9s"/>

          <!-- source nodes -->
          <g><rect class="node-rect" x="24" y="36" width="152" height="38" rx="7"/><text class="node-text" x="42" y="59">SecOps Solution</text></g>
          <g><rect class="node-rect" x="24" y="82" width="152" height="38" rx="7"/><text class="node-text" x="42" y="105">Tenable</text></g>
          <g><rect class="node-rect" x="24" y="128" width="152" height="38" rx="7"/><text class="node-text" x="42" y="151">Qualys</text></g>
          <g><rect class="node-rect" x="24" y="174" width="152" height="38" rx="7"/><text class="node-text" x="42" y="197">Defender VM</text></g>
          <g><rect class="node-rect" x="24" y="220" width="152" height="38" rx="7"/><text class="node-text" x="42" y="243">CrowdStrike</text></g>
          <g><rect class="node-rect" x="24" y="266" width="152" height="38" rx="7"/><text class="node-text" x="42" y="289">Rapid7</text></g>
          <g><rect class="node-rect" x="24" y="312" width="152" height="38" rx="7"/><text class="node-text" x="42" y="335">Cortex</text></g>
          <g><rect class="node-rect" x="24" y="358" width="152" height="38" rx="7"/><text class="node-text" x="42" y="381">Zscaler</text></g>

          <!-- threat & exploit intel -->
          <g><rect class="node-rect" x="380" y="20" width="240" height="36" rx="7"/><text class="node-text" x="400" y="42">THREAT · EXPLOIT INTELLIGENCE</text></g>

          <!-- engine -->
          <rect class="node-rect engine" x="380" y="132" width="240" height="150" rx="12"/>
          <text class="engine-title" x="412" y="186">EX-LAYER ENGINE</text>
