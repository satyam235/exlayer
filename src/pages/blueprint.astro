<script is:inline>
const nav=document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>20));
const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.15});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
function countUp(el){const to=parseFloat(el.dataset.to),suf=el.dataset.suffix||'',dur=1500,t0=performance.now();
  function tick(t){let p=Math.min((t-t0)/dur,1);p=1-Math.pow(1-p,3);let v=to*p;el.textContent=(suf?v.toFixed(1):Math.round(v));
    if(p<1)requestAnimationFrame(tick);else el.textContent=(suf?to.toFixed(1):to);}requestAnimationFrame(tick);}
const cuio=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){countUp(e.target);cuio.unobserve(e.target);}})},{threshold:.6});
document.querySelectorAll('.cu').forEach(el=>cuio.observe(el));
// engine terminal
const lines=[
  {t:'00:00.2',st:'RESOLVE',ms:'intent → <span class="tk c">PATCH_DEPLOYMENT</span>'},
  {t:'00:00.8',st:'CORRELATE',ms:'412 findings → <b style="color:var(--t1)">128</b> unique'},
  {t:'00:01.4',st:'TARGET',ms:'<b style="color:var(--t1)">17</b> assets · <span class="tk k">1 exploited</span>'},
  {t:'00:02.0',st:'PLAN',ms:'pilot ring 3 → full rollout'},
  {t:'00:02.6',st:'READY',ms:'<span class="tk o">draft ready</span> — review'},
];
const body=document.getElementById('termBody');let li=0,started=false;
function typeLine(){
  if(li>=lines.length){setTimeout(()=>{body.innerHTML='';li=0;typeLine();},2600);return;}
  const l=lines[li];const div=document.createElement('div');div.className='tl';
  div.innerHTML=`<span class="tm">${l.t}</span><span class="st">${l.st}</span><span class="ms">${l.ms}<span class="caret"></span></span>`;
  body.appendChild(div);requestAnimationFrame(()=>div.classList.add('show'));
  const cs=body.querySelectorAll('.caret');cs.forEach((c,i)=>{if(i<cs.length-1)c.remove();});
  li++;setTimeout(typeLine,li===lines.length?800:650);
}
const tio=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting&&!started){started=true;setTimeout(typeLine,400);}})},{threshold:.4});
tio.observe(document.querySelector('.term'));

// schematic: campaigns flip to "remediated" one by one, then reset & loop
(function(){
  const camps=Array.from(document.querySelectorAll('.camp'));
  if(!camps.length)return;
  if(matchMedia('(prefers-reduced-motion: reduce)').matches){camps.forEach(c=>c.classList.add('remediated'));return;}
  function cycle(){
    camps.forEach(c=>c.classList.remove('remediated'));
    camps.forEach((c,i)=>setTimeout(()=>c.classList.add('remediated'),1600+i*560));
    setTimeout(cycle,1600+camps.length*560+3000);
  }
  cycle();
})();
</script>
